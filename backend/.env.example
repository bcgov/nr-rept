# ===========================================
# REPT Backend Environment Variables
# ===========================================
# Copy this file to .env and fill in the values
# Recommended to set sensitive values directly in the terminal environment for security
# Also i have seen these work better if set directly in terminal environment for spring boot apps

# Server Configuration
SERVER_PORT=3000

# Security
APP_SECURITY_DISABLED=false

# Spring Profiles (oracle for Oracle DB connection)
SPRING_PROFILES_ACTIVE=oracle

# AWS Cognito Configuration
AWS_COGNITO_ISSUER_URI=https://cognito-idp.ca-central-1.amazonaws.com/YOUR_USER_POOL_ID

# FAM User Lookup Service
IDENTITY_LOOKUP_BASE_URL=

# Database Configuration (Oracle - plain TCP, port 1521, no SSL required)
DATABASE_HOST=
SERVICE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=

# Jasper Reports Configuration
J_URL_FETCH=
J_USERNAME=
J_PASSWORD=
J_CONNECT_TIMEOUT=10s
J_READ_TIMEOUT=60s

# Frontend CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000

# Logging
LOGGING_LEVEL=INFO
