# Loaded by `vite build` (mode=production). Only universal values belong here —
# they get baked into the bundle as `import.meta.env.X`. Environment-specific
# VITE_* values (Cognito pool, backend URL, zone, etc.) are injected at runtime
# by frontend/docker-entrypoint.sh into /srv/config.js and merged over
# import.meta.env by src/env.ts, so the same image serves DEV/TEST/PROD.
VITE_BASE_PATH=/
